# DevClip Sync Server Environment Configuration
# Copy this file to .env and fill in your values

# ================================================
# Server Configuration
# ================================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ================================================
# Database (PostgreSQL)
# ================================================
DATABASE_URL=postgresql://user:password@localhost:5432/devclip
# Or individual components:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=devclip
# PGUSER=devclip
# PGPASSWORD=your_secure_password

# ================================================
# Security & Encryption
# ================================================
# 32+ byte hex string for audit log signing
AUDIT_SECRET=your_secure_random_64_character_hex_string_here

# JWT Configuration
JWT_SECRET=your_jwt_signing_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ================================================
# License Key Signing (RSA 4096-bit)
# ================================================
# For offline/air-gapped license generation
# Generate keys with: node scripts/cli/license-cli.mjs generate-keys

# Private key (PEM format) - KEEP SECRET!
# Can be a path to file OR the key content directly
LICENSE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----

# Public key (PEM format) - Safe to distribute
# Can be a path to file OR the key content directly
LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----

# ================================================
# Email/SMTP (for notifications)
# ================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@devclip.app
SMTP_PASS=your_app_specific_password
SMTP_FROM=DevClip <notifications@devclip.app>

# ================================================
# External APIs (optional)
# ================================================
# AI Provider (if providing AI features)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Error Tracking
SENTRY_DSN=https://...@....ingest.sentry.io/...

# Analytics
PLAUSIBLE_DOMAIN=yourdomain.com
PLAUSIBLE_API_KEY=...

# ================================================
# Sync/WebSocket Settings
# ================================================
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS_PER_USER=5
SYNC_RATE_LIMIT_PER_MINUTE=60

# ================================================
# Enterprise Features
# ================================================
# Max policy size in KB
MAX_POLICY_SIZE_KB=100
# Default policy cache TTL in seconds
POLICY_CACHE_TTL=300
